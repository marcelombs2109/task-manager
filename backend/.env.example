# Copia este archivo como .env y completa los valores

# Puerto del servidor (Render lo asigna automáticamente)
PORT=3020

# Entorno: development | production
NODE_ENV=development

# URL del frontend (solo importa en producción para CORS)
# Ejemplo: https://tu-app.onrender.com
CLIENT_URL=http://localhost:5173

# Ruta del archivo SQLite
# En Render con disco persistente usar: /data/tasks.db
# En local dejar vacío (usa la carpeta db/ por defecto)
DB_PATH=
